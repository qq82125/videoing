# Quality-first configuration
OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=https://api.openai.com
OPENAI_AUTH_HEADER=Authorization
OPENAI_AUTH_SCHEME=Bearer
OPENAI_TEXT_API_KIND=responses
OPENAI_TEXT_ENDPOINT=/v1/responses
OPENAI_TEXT_MODEL=gpt-5.2
OPENAI_IMAGE_ENDPOINT=/v1/images/generations
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_QUALITY=high
OPENAI_IMAGE_SIZE=1024x1536
OPENAI_IMAGE_OUTPUT_FORMAT=png
OPENAI_TTS_ENDPOINT=/v1/audio/speech
OPENAI_TTS_MODEL=tts-1-hd
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_FORMAT=mp3
OPENAI_MODERATION_ENDPOINT=/v1/moderations
OPENAI_MODERATION_MODEL=omni-moderation-latest
LOCAL_TTS_VOICE=Ting-Ting
PORT=3016
